# Local development example only. Do not use these values in staging or production.
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Local frontend origins. Staging/production must set the real Lovable/frontend origin.
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Local database only. Staging/production must use a secret-managed PostgreSQL URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workforce_management?schema=public

# Local placeholder secrets only. Replace with high-entropy secret-managed values outside development/test.
JWT_SECRET=replace-with-development-jwt-secret
JWT_ACCESS_SECRET=replace-with-development-access-secret
JWT_REFRESH_SECRET=replace-with-development-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CP8 uses the mock provider locally. Real biometric vendor configuration is future production work.
FACE_PROVIDER=mock
STORAGE_PROVIDER=local

# Future integrations only. Leave unset until the corresponding checkpoint/provider is implemented.
STRIPE_SECRET_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
EMAIL_PROVIDER=
