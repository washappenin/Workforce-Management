generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
  SUSPENDED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum RoleName {
  SUPER_ADMIN
  COMPANY_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum AttendanceEventType {
  CLOCK_IN
  CLOCK_OUT
  LOCATION_PING
  GEOFENCE_BREACH
  FACE_VERIFICATION
  MANUAL_NOTE
}

enum GeofenceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum GeofenceBreachType {
  OUTSIDE_GEOFENCE
  GPS_DISABLED
  LOW_ACCURACY
  UNKNOWN
}

enum FaceEnrollmentStatus {
  NOT_ENROLLED
  PENDING
  ACTIVE
  DISABLED
  FAILED
}

enum ShiftStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveTypeStatus {
  ACTIVE
  INACTIVE
}

enum OKRStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  ARCHIVED
}

enum OKRApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum PerformanceReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  ARCHIVED
}

enum NotificationType {
  SYSTEM
  ATTENDANCE
  LEAVE
  OKR
  PERFORMANCE
  SUBSCRIPTION
  SECURITY
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum SubscriptionPlanType {
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum AuditActionCategory {
  AUTH
  USER
  COMPANY
  EMPLOYEE
  ROLE
  GEOFENCE
  ATTENDANCE
  FACE_VERIFICATION
  SHIFT
  LEAVE
  OKR
  PERFORMANCE
  NOTIFICATION
  SUBSCRIPTION
  PAYMENT
  SECURITY
  SYSTEM
}

enum DeviceSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id             String          @id @default(cuid())
  email          String
  passwordHash   String
  status         UserStatus      @default(INVITED)
  companyId      String?
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company        Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  employeeProfile EmployeeProfile?
  userRoles      UserRole[]
  notifications  Notification[]
  auditLogs      AuditLog[]      @relation("AuditActor")
  deviceSessions DeviceSession[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model Company {
  id                   String                @id @default(cuid())
  name                 String
  status               CompanyStatus         @default(ACTIVE)
  contactEmail         String?
  contactPhone         String?
  billingEmail         String?
  address              String?
  country              String?
  timezone             String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  users                User[]
  departments          Department[]
  designations         Designation[]
  employeeProfiles     EmployeeProfile[]
  userRoles            UserRole[]
  geofences            Geofence[]
  faceEnrollments      FaceEnrollment[]
  attendanceSessions   AttendanceSession[]
  attendanceEvents     AttendanceEvent[]
  locationPings        LocationPing[]
  geofenceBreaches     GeofenceBreach[]
  shifts               Shift[]
  shiftAssignments     EmployeeShiftAssignment[]
  leaveTypes           LeaveType[]
  leaveEntitlements    LeaveEntitlement[]
  leaveRequests        LeaveRequest[]
  okrs                 OKR[]
  okrProgressUpdates   OKRProgressUpdate[]
  okrApprovals         OKRApproval[]
  reviewCycles         ReviewCycle[]
  performanceReviews   PerformanceReview[]
  notifications        Notification[]
  subscriptions        CompanySubscription[]
  paymentRecords       PaymentRecord[]
  auditLogs            AuditLog[]
  deviceSessions       DeviceSession[]

  @@unique([name])
  @@index([status])
  @@index([createdAt])
}

model Department {
  id               String            @id @default(cuid())
  companyId        String
  name             String
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  designations     Designation[]
  employeeProfiles EmployeeProfile[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isActive])
  @@index([createdAt])
}

model Designation {
  id               String            @id @default(cuid())
  companyId        String
  departmentId     String?
  title            String
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employeeProfiles EmployeeProfile[]

  @@unique([companyId, title])
  @@index([companyId])
  @@index([departmentId])
  @@index([isActive])
  @@index([createdAt])
}

model EmployeeProfile {
  id                       String                    @id @default(cuid())
  companyId                String
  userId                   String                    @unique
  departmentId             String?
  designationId            String?
  managerId                String?
  employeeCode             String
  firstName                String
  lastName                 String
  phone                    String?
  status                   EmployeeStatus            @default(ACTIVE)
  hireDate                 DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  company                  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department               Department?               @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation              Designation?              @relation(fields: [designationId], references: [id], onDelete: SetNull)
  manager                  EmployeeProfile?          @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports            EmployeeProfile[]         @relation("EmployeeManager")
  faceEnrollment           FaceEnrollment?
  attendanceSessions       AttendanceSession[]
  attendanceEvents         AttendanceEvent[]
  locationPings            LocationPing[]
  geofenceBreaches         GeofenceBreach[]
  shiftAssignments         EmployeeShiftAssignment[]
  leaveEntitlements        LeaveEntitlement[]
  leaveRequests            LeaveRequest[]
  reviewedLeaveRequests    LeaveRequest[]            @relation("LeaveRequestReviewer")
  okrs                     OKR[]                     @relation("OKREmployee")
  assignedOkrs             OKR[]                     @relation("OKRAssignedBy")
  okrProgressUpdates       OKRProgressUpdate[]
  okrApprovals             OKRApproval[]             @relation("OKRApprover")
  performanceReviews       PerformanceReview[]       @relation("PerformanceReviewEmployee")
  managerReviews           PerformanceReview[]       @relation("PerformanceReviewManager")

  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([departmentId])
  @@index([designationId])
  @@index([managerId])
  @@index([status])
  @@index([createdAt])
}

model Role {
  id          String       @id @default(cuid())
  name        RoleName     @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userRoles   UserRole[]
  permissions Permission[]

  @@index([createdAt])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles       Role[]

  @@index([createdAt])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  companyId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId])
  @@index([userId])
  @@index([roleId])
  @@index([companyId])
  @@index([createdAt])
}

model Geofence {
  id                  String              @id @default(cuid())
  companyId           String
  name                String
  latitude            Decimal             @db.Decimal(9, 6)
  longitude           Decimal             @db.Decimal(9, 6)
  radiusMeters        Int
  status              GeofenceStatus      @default(ACTIVE)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clockInSessions     AttendanceSession[] @relation("ClockInGeofence")
  clockOutSessions    AttendanceSession[] @relation("ClockOutGeofence")
  breaches            GeofenceBreach[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model FaceEnrollment {
  id                String               @id @default(cuid())
  companyId         String
  employeeId        String               @unique
  provider          String
  providerSubjectId String?
  templateReference String?
  status            FaceEnrollmentStatus @default(NOT_ENROLLED)
  enrolledAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee          EmployeeProfile      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

model AttendanceSession {
  id                  String             @id @default(cuid())
  companyId           String
  employeeId          String
  clockInAt           DateTime
  clockOutAt          DateTime?
  clockInLatitude     Decimal            @db.Decimal(9, 6)
  clockInLongitude    Decimal            @db.Decimal(9, 6)
  clockOutLatitude    Decimal?           @db.Decimal(9, 6)
  clockOutLongitude   Decimal?           @db.Decimal(9, 6)
  status              AttendanceStatus   @default(OPEN)
  clockInFaceVerified Boolean            @default(false)
  clockInGeofenceId   String?
  clockOutGeofenceId  String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            EmployeeProfile    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockInGeofence     Geofence?          @relation("ClockInGeofence", fields: [clockInGeofenceId], references: [id], onDelete: SetNull)
  clockOutGeofence    Geofence?          @relation("ClockOutGeofence", fields: [clockOutGeofenceId], references: [id], onDelete: SetNull)
  events              AttendanceEvent[]
  locationPings       LocationPing[]
  geofenceBreaches    GeofenceBreach[]

  @@index([companyId])
  @@index([employeeId])
  @@index([employeeId, status])
  @@index([companyId, status])
  @@index([clockInAt])
  @@index([clockOutAt])
  @@index([createdAt])
}

model AttendanceEvent {
  id                  String             @id @default(cuid())
  companyId           String
  employeeId          String
  attendanceSessionId String?
  type                AttendanceEventType
  latitude            Decimal?           @db.Decimal(9, 6)
  longitude           Decimal?           @db.Decimal(9, 6)
  metadata            Json?
  createdAt           DateTime           @default(now())

  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            EmployeeProfile    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceSession   AttendanceSession? @relation(fields: [attendanceSessionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([attendanceSessionId])
  @@index([type])
  @@index([createdAt])
}

model LocationPing {
  id                  String             @id @default(cuid())
  companyId           String
  employeeId          String
  attendanceSessionId String?
  latitude            Decimal            @db.Decimal(9, 6)
  longitude           Decimal            @db.Decimal(9, 6)
  accuracyMeters      Decimal?           @db.Decimal(8, 2)
  capturedAt          DateTime
  createdAt           DateTime           @default(now())

  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            EmployeeProfile    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceSession   AttendanceSession? @relation(fields: [attendanceSessionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([attendanceSessionId])
  @@index([capturedAt])
  @@index([createdAt])
}

model GeofenceBreach {
  id                  String             @id @default(cuid())
  companyId           String
  employeeId          String
  attendanceSessionId String?
  geofenceId          String?
  type                GeofenceBreachType
  latitude            Decimal?           @db.Decimal(9, 6)
  longitude           Decimal?           @db.Decimal(9, 6)
  detectedAt          DateTime
  createdAt           DateTime           @default(now())

  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            EmployeeProfile    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceSession   AttendanceSession? @relation(fields: [attendanceSessionId], references: [id], onDelete: SetNull)
  geofence            Geofence?          @relation(fields: [geofenceId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([attendanceSessionId])
  @@index([geofenceId])
  @@index([type])
  @@index([detectedAt])
  @@index([createdAt])
}

model Shift {
  id          String                    @id @default(cuid())
  companyId   String
  name        String
  startTime   String
  endTime     String
  status      ShiftStatus               @default(ACTIVE)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  company     Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments EmployeeShiftAssignment[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model EmployeeShiftAssignment {
  id         String          @id @default(cuid())
  companyId  String
  employeeId String
  shiftId    String
  startsOn   DateTime
  endsOn     DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift      Shift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftId, startsOn])
  @@index([companyId])
  @@index([employeeId])
  @@index([shiftId])
  @@index([startsOn])
  @@index([createdAt])
}

model LeaveType {
  id                     String             @id @default(cuid())
  companyId              String
  name                   String
  status                 LeaveTypeStatus    @default(ACTIVE)
  defaultAnnualAllowance Decimal?           @db.Decimal(6, 2)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  company                Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entitlements           LeaveEntitlement[]
  requests               LeaveRequest[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model LeaveEntitlement {
  id          String          @id @default(cuid())
  companyId   String
  employeeId  String
  leaveTypeId String
  year        Int
  totalDays   Decimal         @db.Decimal(6, 2)
  usedDays    Decimal         @default(0) @db.Decimal(6, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType       @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([companyId])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([year])
  @@index([createdAt])
}

model LeaveRequest {
  id            String             @id @default(cuid())
  companyId     String
  employeeId    String
  leaveTypeId   String
  startDate     DateTime
  endDate       DateTime
  reason        String?
  status        LeaveRequestStatus @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  reviewComment String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee      EmployeeProfile    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType     LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  reviewedBy    EmployeeProfile?   @relation("LeaveRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([reviewedById])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
}

model OKR {
  id              String              @id @default(cuid())
  companyId       String
  employeeId      String
  assignedById    String
  title           String
  description     String?
  status          OKRStatus           @default(ASSIGNED)
  dueDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        EmployeeProfile     @relation("OKREmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  assignedBy      EmployeeProfile     @relation("OKRAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  progressUpdates OKRProgressUpdate[]
  approvals       OKRApproval[]

  @@index([companyId])
  @@index([employeeId])
  @@index([assignedById])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

model OKRProgressUpdate {
  id              String          @id @default(cuid())
  companyId       String
  okrId           String
  employeeId      String
  progressPercent Int
  note            String?
  createdAt       DateTime        @default(now())

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  okr             OKR             @relation(fields: [okrId], references: [id], onDelete: Cascade)
  employee        EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([okrId])
  @@index([employeeId])
  @@index([createdAt])
}

model OKRApproval {
  id                 String            @id @default(cuid())
  companyId          String
  okrId              String
  approverEmployeeId String
  status             OKRApprovalStatus @default(PENDING)
  comment            String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  okr                OKR               @relation(fields: [okrId], references: [id], onDelete: Cascade)
  approver           EmployeeProfile   @relation("OKRApprover", fields: [approverEmployeeId], references: [id], onDelete: Restrict)

  @@unique([okrId, approverEmployeeId])
  @@index([companyId])
  @@index([okrId])
  @@index([approverEmployeeId])
  @@index([status])
  @@index([createdAt])
}

model ReviewCycle {
  id                 String                 @id @default(cuid())
  companyId          String
  name               String
  startDate          DateTime
  endDate            DateTime
  status             ReviewCycleStatus      @default(DRAFT)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  performanceReviews PerformanceReview[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
}

model PerformanceReview {
  id            String                  @id @default(cuid())
  companyId     String
  reviewCycleId String
  employeeId    String
  managerId     String
  summary       String
  rating        Decimal?                @db.Decimal(3, 2)
  status        PerformanceReviewStatus @default(DRAFT)
  submittedAt   DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewCycle   ReviewCycle             @relation(fields: [reviewCycleId], references: [id], onDelete: Cascade)
  employee      EmployeeProfile         @relation("PerformanceReviewEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  manager       EmployeeProfile         @relation("PerformanceReviewManager", fields: [managerId], references: [id], onDelete: Restrict)

  @@unique([reviewCycleId, employeeId])
  @@index([companyId])
  @@index([reviewCycleId])
  @@index([employeeId])
  @@index([managerId])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String             @id @default(cuid())
  companyId String?
  userId    String
  type      NotificationType
  status    NotificationStatus @default(UNREAD)
  title     String
  message   String
  metadata  Json?
  createdAt DateTime           @default(now())
  readAt    DateTime?

  company   Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model SubscriptionPlan {
  id               String                @id @default(cuid())
  name             String
  type             SubscriptionPlanType
  pricePerEmployee Decimal               @db.Decimal(12, 2)
  currency         String                @default("USD")
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  subscriptions    CompanySubscription[]

  @@unique([name])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}

model CompanySubscription {
  id             String             @id @default(cuid())
  companyId      String
  planId         String
  status         SubscriptionStatus @default(ACTIVE)
  startsAt       DateTime
  endsAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan           SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  paymentRecords PaymentRecord[]

  @@index([companyId])
  @@index([planId])
  @@index([companyId, status])
  @@index([status])
  @@index([startsAt])
  @@index([createdAt])
}

model PaymentRecord {
  id                String               @id @default(cuid())
  companyId         String
  subscriptionId    String?
  amount            Decimal              @db.Decimal(12, 2)
  currency          String               @default("USD")
  status            PaymentStatus        @default(PENDING)
  provider          String?
  providerReference String?
  paidAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription      CompanySubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([subscriptionId])
  @@index([status])
  @@index([providerReference])
  @@index([paidAt])
  @@index([createdAt])
}

model AuditLog {
  id          String              @id @default(cuid())
  companyId   String?
  actorUserId String?
  category    AuditActionCategory
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime            @default(now())

  company     Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actorUser   User?               @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([actorUserId])
  @@index([category])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model DeviceSession {
  id         String              @id @default(cuid())
  companyId  String?
  userId     String
  deviceId   String?
  platform   String?
  status     DeviceSessionStatus @default(ACTIVE)
  lastSeenAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  company    Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
