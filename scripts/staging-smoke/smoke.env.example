# Copy this file to scripts/staging-smoke/smoke.env and fill it locally.
# smoke.env is gitignored. Never commit staging passwords or tokens.
# Quote values that contain spaces or shell-special characters.

BASE_URL=https://workforce-management-production.up.railway.app
EXPECTED_ENVIRONMENT=staging

# Optional. When set, 01-infrastructure.sh verifies the CORS preflight response.
FRONTEND_ORIGIN=

# Existing synthetic accounts used by 02-auth-and-boundaries.sh.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
COMPANY_ADMIN_EMAIL=
COMPANY_ADMIN_PASSWORD=
HR_ADMIN_EMAIL=
HR_ADMIN_PASSWORD=
MANAGER_EMAIL=
MANAGER_PASSWORD=
EMPLOYEE_EMAIL=
EMPLOYEE_PASSWORD=

# Optional company outside COMPANY_ADMIN_EMAIL's company scope.
OTHER_COMPANY_ID=

# 03-core-workflow.sh creates a timestamped company and four role accounts.
# Set this to true only when you intend to create persistent synthetic staging data.
RUN_CORE_WORKFLOW=false
CORE_ACCOUNT_PASSWORD=
CORE_EMAIL_DOMAIN=example.test
CORE_COMPANY_PREFIX="Staging Smoke"
GEOFENCE_LATITUDE=9.0301
GEOFENCE_LONGITUDE=38.7400
GEOFENCE_RADIUS_METERS=200
